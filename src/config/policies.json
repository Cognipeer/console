{
  "features": {
    "USER_MANAGEMENT": {
      "name": "User Management",
      "description": "Create and manage users",
      "endpoints": [
        "/api/users",
        "/api/users/*"
      ]
    },
    "DASHBOARD": {
      "name": "Dashboard",
      "description": "Access to dashboard endpoints",
      "endpoints": [
        "/api/dashboard",
        "/api/dashboard/*"
      ]
    },
    "PROJECT_MANAGEMENT": {
      "name": "Project Management",
      "description": "Create and manage projects",
      "endpoints": [
        "/api/projects",
        "/api/projects/*"
      ]
    },
    "LLM_CHAT": {
      "name": "LLM Chat Service",
      "description": "Access to LLM chat endpoints",
      "endpoints": [
        "/api/llm/chat",
        "/api/llm/chat/*"
      ]
    },
    "LLM_EMBEDDINGS": {
      "name": "LLM Embeddings",
      "description": "Generate text embeddings",
      "endpoints": [
        "/api/llm/embeddings",
        "/api/llm/embeddings/*"
      ]
    },
    "MODEL_MANAGEMENT": {
      "name": "Model Management",
      "description": "Manage and deploy AI models",
      "endpoints": [
        "/api/models",
        "/api/models/*"
      ]
    },
    "PROMPTS": {
      "name": "Prompt Management",
      "description": "Create and render prompt templates",
      "endpoints": [
        "/api/prompts",
        "/api/prompts/*",
        "/api/client/v1/prompts",
        "/api/client/v1/prompts/*"
      ]
    },
    "AGENT_ORCHESTRATION": {
      "name": "Agent Orchestration",
      "description": "Create and manage AI agents",
      "endpoints": [
        "/api/agents",
        "/api/agents/*"
      ]
    },
    "AGENT_TRACING": {
      "name": "Agent Tracing",
      "description": "Capture and inspect agent sessions and events",
      "endpoints": [
        "/api/tracing",
        "/api/tracing/*"
      ]
    },
    "VECTOR_STORE": {
      "name": "Vector Store",
      "description": "Store and query vector embeddings",
      "endpoints": [
        "/api/vector",
        "/api/vector/*",
        "/api/client/vector",
        "/api/client/vector/*"
      ]
    },
    "API_KEYS": {
      "name": "API Key Management",
      "description": "Create and manage API keys",
      "endpoints": [
        "/api/keys",
        "/api/keys/*",
        "/api/tokens",
        "/api/tokens/*"
      ]
    },
    "FILES": {
      "name": "File Management",
      "description": "Upload and manage files",
      "endpoints": [
        "/api/files",
        "/api/files/*",
        "/api/providers",
        "/api/providers/*"
      ]
    },
    "QUOTA_MANAGEMENT": {
      "name": "Quota Management",
      "description": "Manage tenant quota policies and limits",
      "endpoints": [
        "/api/quota",
        "/api/quota/*"
      ]
    }
  },
  "licenses": {
    "FREE": {
      "name": "Free Tier",
      "features": [
        "USER_MANAGEMENT",
        "PROJECT_MANAGEMENT",
        "LLM_CHAT",
        "AGENT_TRACING",
        "API_KEYS",
        "MODEL_MANAGEMENT",
        "PROMPTS",
        "VECTOR_STORE",
        "FILES",
        "QUOTA_MANAGEMENT",
        "DASHBOARD"
      ],
      "limits": {
        "requestsPerMonth": 1000,
        "maxAgents": -1
      }
    },
    "STARTER": {
