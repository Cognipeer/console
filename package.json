    "mustache": "^4.2.0",
    "next": "15.5.4",
    "nodemailer": "^7.0.6",
    "pg": "^8.20.0",
    "postcss": "^8.5.6",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-json-view-lite": "^2.5.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "remark-gfm": "^4.0.1",
