{
  "name": "cognipeer-console",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "scripts": {
    "dev": "NODE_ENV=development node --import tsx src/server/index.ts --dev",
    "build": "next build",
    "start": "NODE_ENV=production node --import tsx src/server/index.ts",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "format": "prettier --log-level warn --no-error-on-unmatched-pattern --write ./src/{,*/**/,*/**/**/,*/**/**/**/}*.{js,jsx,ts}",
    "check-setup": "node scripts/check-setup.js",
    "seed:demo": "node --env-file=.env.local scripts/demo/seed.mjs",
    "seed:demo:reset": "node --env-file=.env.local scripts/demo/seed.mjs --reset",
    "seed:demo:status": "node --env-file=.env.local scripts/demo/seed.mjs --status",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.901.0",
