  "scripts": {
    "dev": "NODE_ENV=development node --import tsx src/server/index.ts --dev",
    "dev:watch": "NODE_ENV=development node --watch --watch-path=src --import tsx src/server/index.ts --dev",
    "build": "next build",
    "start": "NODE_ENV=production node --import tsx src/server/index.ts",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:endpoints": "tsx scripts/check-endpoint-coverage.ts",
    "test:smoke": "node --import tsx scripts/smoke/run.ts",
    "test:flake": "tsx scripts/flake-hunter.ts",
    "format": "prettier --log-level warn --no-error-on-unmatched-pattern --write ./src/{,*/**/,*/**/**/,*/**/**/**/}*.{js,jsx,ts}",
    "check-setup": "node scripts/check-setup.js",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
